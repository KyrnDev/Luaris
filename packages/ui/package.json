{
	"name": "@luaris/ui",
	"version": "0.0.0",
	"type": "module",
	"sideEffects": [
		"**/*.css",
		"**/*.scss"
	],
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./components/*": {
			"types": "./dist/components/*/index.d.ts",
			"import": "./dist/components/*/index.js"
		},
		"./directives": {
			"types": "./dist/directives/index.d.ts",
			"import": "./dist/directives/index.js"
		},
		"./register": {
			"types": "./dist/register.d.ts",
			"import": "./dist/register/index.js"
		},
		"./styles": "./dist/styles.css",
		"./styles.css": "./dist/styles.css",
		"./package.json": "./package.json"
	},
	"scripts": {
		"barrel:generate": "bun run scripts/generate-barrel.ts",
		"dev": "bun run barrel:generate && vite",
		"build": "bun run barrel:generate && rm -rf dist && vite build && vue-tsc -p tsconfig.build.json",
		"preview": "vite preview",
		"fa:registry": "bun run scripts/generate-fa-registry.ts",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"vue": "^3.5.25"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vitest/coverage-v8": "^4.1.5",
		"@vue/test-utils": "^2.4.10",
		"@vue/tsconfig": "^0.9.1",
		"jsdom": "^29.1.1",
		"sass-embedded": "^1.99.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"vue": "^3.5.33",
		"vue-tsc": "^3.2.7"
	}
}
