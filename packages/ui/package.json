{
  "name": "@luaris/ui",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
	"./components/flex": {
	  "types": "./dist/components/flex/index.d.ts",
	  "import": "./dist/components/flex/index.js"
	},
	"./components/icon": {
	  "types": "./dist/components/icon/index.d.ts",
	  "import": "./dist/components/icon/index.js"
	},
	"./components/page": {
	  "types": "./dist/components/page/index.d.ts",
	  "import": "./dist/components/page/index.js"
	},
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./directives": {
      "types": "./dist/directives/index.d.ts",
      "import": "./dist/directives/index.js"
    },
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build && vue-tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "fa:registry": "bun run scripts/generate-fa-registry.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "peerDependencies": {
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^28.1.0",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.0.18",
    "vue": "^3.5.28",
    "vue-tsc": "^3.2.4"
  }
}
