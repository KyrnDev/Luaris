{
  "name": "@luaris/ui",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./components/flex": {
      "types": "./dist/components/flex/index.d.ts",
      "import": "./dist/components/flex/index.js"
    },
    "./components/icon": {
      "types": "./dist/components/icon/index.d.ts",
      "import": "./dist/components/icon/index.js"
    },
    "./components/page": {
      "types": "./dist/components/page/index.d.ts",
      "import": "./dist/components/page/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./directives": {
      "types": "./dist/directives/index.d.ts",
      "import": "./dist/directives/index.js"
    },
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build && vue-tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "fa:registry": "bun run scripts/generate-fa-registry.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "sass-embedded": "^1.99.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  }
}
