{
  "name": "monorepo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "hooks:setup": "git config core.hooksPath .githooks",
    "lint": "eslint",
    "test": "bun run --filter \"@luaris/ui\" test:run",
    "test:coverage": "bun run --filter \"@luaris/ui\" test:coverage",
    "ui:dev": "bun run --filter \"@luaris/ui\" dev",
    "ui:screenshot": "bun run ./scripts/capture-ui-screenshot.ts --ready-selector=.lx-app-page",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/bun": "latest",
    "eslint": "^10.3.0",
    "playwright": "^1.59.1",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}